{
  "title": "Amazing Grace",
  "artist": "John Newton",
  "key": "G",
  "timeSignature": "3/4",
  "difficulty": "nybörjare",
  "sections": [
    {
      "label": "Vers 1",
      "lines": [
        {
          "c": "@vers_a",
          "l": "Amazing |Grace, how |sweet, the| sound"
        },
        {
          "c": "@vers_b",
          "l": "that saved a |wretch like |me|"
        },
        {
          "c": "@vers_c",
          "l": "I once was  |lost but |now am |found"
        },
        {
          "c": "@vers_d",
          "l": "was blind, but |now    I |see|"
        }
      ]
    },
    {
      "label": "Vers 2",
      "lines": [
        {
          "c": "@vers_a",
          "l": "'Twas grace that |taught my |heart to |fear"
        },
        {
          "c": "@vers_b",
          "l": "and grace my |fears|relieved|"
        },
        {
          "c": "@vers_c",
          "l": "How precious |did that |grace |appear"
        },
        {
          "c": "@vers_e",
          "l": "the hour I |first |believed | "
        }
      ]
    },
    {
      "label": "Vers 3",
      "lines": [
        {
          "c": "A            D|         A",
          "l": "Through many dangers, |toils and snares"
        },
        {
          "c": "  A      |    E",
          "l": "I have   |already come"
        },
        {
          "c": "A          A7    D|         A",
          "l": "Tis' grace hath brought |me safe thus far"
        },
        {
          "c": "F#m      E|    A       D/E",
          "l": "And grace |will lead me home"
        }
      ]
    },
    {
      "label": "Vers 4",
      "lines": [
        {
          "c": "A            D|         A",
          "l": "When we've been |there ten thousand years,"
        },
        {
          "c": "A        |     E7",
          "l": "bright   |shining as the sun,"
        },
        {
          "c": "A      A7        D|         A",
          "l": "We've no less days |to sing God's praise"
        },
        {
          "c": "F#m    E|    A      F#",
          "l": "than when|we first begun."
        }
      ]
    },
    {
      "label": "Vers 5",
      "lines": [
        {
          "c": "B            E|         B",
          "l": "Amazing Grace, |how sweet the sound,"
        },
        {
          "c": "             |        F#7",
          "l": "That saved a |wretch like me."
        },
        {
          "c": "B      B7        E|         B",
          "l": "I once was lost, |but now am found,"
        },
        {
          "c": "G#m       F#7|     G#m  E",
          "l": "Was blind, |but now I see."
        },
        {
          "c": "C#        F#|     E/B  B",
          "l": "Was blind, |but now I see."
        }
      ]
    }
  ],
  "chordTemplates": {
    "vers_a": "G|G|C/G|G",
    "vers_b": "G|G|D7|D7",
    "vers_c": "G|G7|C|G",
    "vers_d": "Em|D7|G|C/D",
    "vers_e": "Em|D7|G|E7"
  }
}