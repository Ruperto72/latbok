{
  "title": "Uti Vår Hage",
  "artist": "Traditionell (svensk)",
  "key": "Am",
  "timeSignature": "3/4",
  "difficulty": "nybörjare",
  "chordTemplates": {
    "rad_1": "Am F|G C",
    "rad_2": "F|C",
    "rad_3": "Am D7|G",
    "rad_4": "E Am|E",
    "rad_5": "Am|E",
    "rad_6": "Am|Dm",
    "rad_7": "Am E|Am"
  },
  "sections": [
    {
      "label": "Vers 1",
      "lines": [
        {
          "c": "@rad_1",
          "l": "Uti vår hage där |växa blå bär"
        },
        {
          "c": "@rad_2",
          "l": "Kom hjärtans |fröjd!"
        },
        {
          "c": "@rad_3",
          "l": "Vill du mig något |så träffas vi där."
        },
        {
          "c": "@rad_4",
          "l": "Kom liljor |och akvileja,"
        },
        {
          "c": "@rad_5",
          "l": "kom rosor |och salivia"
        },
        {
          "c": "@rad_6",
          "l": "Kom ljuva |krusmynta,"
        },
        {
          "c": "@rad_7",
          "l": "kom, hjärtans |fröjd."
        }
      ]
    },
    {
      "label": "Vers 2",
      "lines": [
        {
          "c": "@rad_1",
          "l": "Fagra små blommor |där bjuda till dans."
        },
        {
          "c": "@rad_2",
          "l": "Kom hjärtans |fröjd!"
        },
        {
          "c": "@rad_3",
          "l": "Vill du så binder |jag åt dig en krans."
        },
        {
          "c": "@rad_4",
          "l": "Kom liljor |och akvileja,"
        },
        {
          "c": "@rad_5",
          "l": "kom rosor |och salivia"
        },
        {
          "c": "@rad_6",
          "l": "Kom ljuva |krusmynta,"
        },
        {
          "c": "@rad_7",
          "l": "kom, hjärtans |fröjd."
        }
      ]
    },
    {
      "label": "Vers 3",
      "lines": [
        {
          "c": "@rad_1",
          "l": "Kransen den sätter |jag sen i ditt hår."
        },
        {
          "c": "@rad_2",
          "l": "Kom hjärtans |fröjd!"
        },
        {
          "c": "@rad_3",
          "l": "Solen den dalar, |men hoppet uppgår."
        },
        {
          "c": "@rad_4",
          "l": "Kom liljor |och akvileja,"
        },
        {
          "c": "@rad_5",
          "l": "kom rosor |och salivia"
        },
        {
          "c": "@rad_6",
          "l": "Kom ljuva |krusmynta,"
        },
        {
          "c": "@rad_7",
          "l": "kom, hjärtans |fröjd."
        }
      ]
    },
    {
      "label": "Vers 4",
      "lines": [
        {
          "c": "@rad_1",
          "l": "Uti vår hage finns |blommor och bär."
        },
        {
          "c": "@rad_2",
          "l": "Kom hjärtans |fröjd!"
        },
        {
          "c": "@rad_3",
          "l": "Men utav alla |du kärast mig är."
        },
        {
          "c": "@rad_4",
          "l": "Kom liljor |och akvileja,"
        },
        {
          "c": "@rad_5",
          "l": "kom rosor |och salivia"
        },
        {
          "c": "@rad_6",
          "l": "Kom ljuva |krusmynta,"
        },
        {
          "c": "@rad_7",
          "l": "kom, hjärtans |fröjd."
        }
      ]
    }
  ]
}
