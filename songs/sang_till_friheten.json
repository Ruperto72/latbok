{
  "title": "Sång till Friheten",
  "artist": "Björn Afzelius",
  "key": "C",
  "timeSignature": "4/4",
  "difficulty": "medel",
  "chordTemplates": {
    "vers_a": "C |F    G|C |F    G",
    "vers_b": "C|F    Dm|G|G",
    "vers_c": "Dm|G|C|Am7",
    "vers_d": "F|Dm|G|G"
  },
  "sections": [
    {
      "label": "Vers 1",
      "lines": [
        {
          "c": "@vers_a",
          "l": "Du är det |finaste jag |vet.|"
        },
        {
          "c": "@vers_b",
          "l": "Du är det |dyraste i |världen.|"
        },
        {
          "c": "@vers_c",
          "l": "Du är som |stjärnorna, som |vindarna, som |vågorna, som "
        },
        {
          "c": "@vers_d",
          "l": "fåglarna, som |blommorna på |marken.|"
        }
      ]
    },
    {
      "label": "Vers 2",
      "lines": [
        {
          "c": "@vers_a",
          "l": "Du är min |ledstjärna och|vän.|"
        },
        {
          "c": "@vers_b",
          "l": "Du är min|tro, mitt hopp, min |kärlek.|"
        },
        {
          "c": "@vers_c",
          "l": "Du är mitt |blod och mina |lungor, mina|ögon, mina"
        },
        {
          "c": "@vers_d",
          "l": "skuldror, mina|händer och mitt|hjärta.|"
        }
      ]
    },
    {
      "label": "Vers 3",
      "lines": [
        {
          "c": "@vers_a",
          "l": "Friheten |är ditt vackra |namn.|"
        },
        {
          "c": "@vers_b",
          "l": "Vänskapen |är din stolta |moder.|"
        },
        {
          "c": "@vers_c",
          "l": "Rättvisan |är din broder, |freden är din |syster, kampen "
        },
        {
          "c": "@vers_d",
          "l": "är din fader, |framtiden ditt |ansvar.|"
        }
      ]
    },
    {
      "label": "Vers 4",
      "lines": [
        {
          "c": "@vers_a",
          "l": "Du är det |finaste jag |vet.|"
        },
        {
          "c": "@vers_b",
          "l": "Du är det |dyraste i |världen.|"
        },
        {
          "c": "@vers_c",
          "l": "Du är som |stjärnorna, som |vindarna, som |vågorna, som "
        },
        {
          "c": "@vers_d",
          "l": " fåglarna, som |blommorna på |marken.|"
        }
      ]
    },
    {
      "label": "Brygga",
      "lines": [
        {
          "c": "D         |G    A      |D   |G  A",
          "l": "Du är det |finaste jag |vet.|"
        },
        {
          "c": "D         |G   Em    |A   |A",
          "l": "Du är det |dyraste i |världen.|"
        },
        {
          "c": "Em        |A               |D             |Bm7",
          "l": "Du är som |stjärnorna, som |vindarna, som |vågorna, som "
        },
        {
          "c": "G             |Em           |A|A",
          "l": "fåglarna, som |blommorna på |marken.|"
        }
      ]
    }
  ]
