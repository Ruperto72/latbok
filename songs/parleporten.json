{
  "title": "Pärleporten",
  "artist": "Christer Sjögren",
  "key": "G",
  "timeSignature": "4/4",
  "difficulty": "intermediate",
  "chordTemplates": {
    "vers_a": "G D7|G|C G|Dsus4",
    "vers_b": "G G/B|C|G/D D7|G",
    "refr_a": "D|G G7|C G|A D"
  },
  "sections": [
    {
      "label": "Intro",
      "lines": [
        {
          "c": "G  C7   Am/E  C  G",
          "l": ""
        }
      ]
    },
    {
      "label": "Vers 1",
      "lines": [
        {
          "c": "@vers_a",
          "l": "Som en härlig |gudomskälla,|rik och mäktig, |djup och stor"
        },
        {
          "c": "@vers_b",
          "l": "är den kärlek, |nåd och sanning|som i Jesu |hjärta bor."
        }
      ]
    },
    {
      "label": "Refräng",
      "lines": [
        {
          "c": "@refr_a",
          "l": "Han har öppnat |pärleporten|så att jag |kan komma in."
        },
        {
          "c": "@vers_b",
          "l": "Genom blodet |har han frälst mig|och bevarat |mig som sin."
        }
      ]
    },
    {
      "label": "Vers 2",
      "lines": [
        {
          "c": "@vers_a",
          "l": "En gång som |en jagad duva,|som en sårad |hjort jag var,"
        },
        {
          "c": "@vers_b",
          "l": "men ett djupt |förkrossat hjärta|Jesus ej |förskjutit har."
        }
      ]
    },
    {
      "label": "Vers 3",
      "lines": [
        {
          "c": "@vers_a",
          "l": "Under över |alla under,|allt förlåt |han mig en gång."
        },
        {
          "c": "@vers_b",
          "l": "Om hans underbara |godhet|glad jag sjunger |nu min sång."
        }
      ]
    },
    {
      "label": "Vers 4",
      "lines": [
        {
          "c": "@vers_a",
          "l": "När en gång |i livets morgon|till den gyllne |port jag når,"
        },
        {
          "c": "@vers_b",
          "l": "då för Jesus |stora kärlek|och för mig |den öppen står."
        }
      ]
    }
  ]
}
