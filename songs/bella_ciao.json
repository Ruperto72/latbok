{
  "title": "Bella Ciao",
  "artist": "Traditionell (italiensk)",
  "key": "Am",
  "timeSignature": "4/4",
  "difficulty": "nybörjare",
  "chordTemplates": {
    "vers1": ".|Am|Am",
    "vers2": ".|Am|A7",
    "vers3": ".|Dm|Am",
    "vers4": ".|E7|Am"
  },
  "sections": [
    {
      "label": "Vers 1",
      "lines": [
        {
          "c": "@vers1",
          "l": "Una |mattina mi sono |alzato."
        },
        {
          "c": "@vers2",
          "l": "O bella, |ciao! Bella, ciao! Bella, |ciao, ciao, ciao!"
        },
        {
          "c": "@vers3",
          "l": "Una |mattina mi sono |alzato."
        },
        {
          "c": "@vers4",
          "l": "E ho |trovato l'inva|sor."
        }
      ]
    },
    {
      "label": "Vers 2",
      "lines": [
        {
          "c": "@vers1",
          "l": "O parti|giano, portami |via."
        },
        {
          "c": "@vers2",
          "l": "O bella, |ciao! Bella, ciao! Bella, |ciao, ciao, ciao!"
        },
        {
          "c": "@vers3",
          "l": "O parti|giano, portami |via, "
        },
        {
          "c": "@vers4",
          "l": "Ché mi |sento di |morir."
        }
      ]
    },
    {
      "label": "Vers 3",
      "lines": [
        {
          "c": "@vers1",
          "l": "E se io |muoio da |partigiano"
        },
        {
          "c": "@vers2",
          "l": "O bella, |ciao! Bella, ciao! Bella, |ciao, ciao, ciao!"
        },
        {
          "c": "@vers3",
          "l": "E se io |muoio da |partigiano"
        },
        {
          "c": "@vers4",
          "l": "tu mi |devi|seppellir."
        }
      ]
    },
    {
      "label": "Vers 4",
      "lines": [
        {
          "c": "@vers1",
          "l": "E |seppellire lassù in |montagna,"
        },
        {
          "c": "@vers2",
          "l": "O bella, |ciao! Bella, ciao! Bella, |ciao, ciao, ciao!"
        },
        {
          "c": "@vers3",
          "l": "E |seppellire lassù in |montagna,"
        },
        {
          "c": "@vers4",
          "l": "sotto |l'ombra di un bel |fior."
        }
      ]
    },
    {
      "label": "Vers 5",
      "lines": [
        {
          "c": "@vers1",
          "l": "E le |genti che |passeranno,"
        },
        {
          "c": "@vers2",
          "l": "O bella, |ciao! Bella, ciao! Bella, |ciao, ciao, ciao!"
        },
        {
          "c": "@vers3",
          "l": "E le |genti che |passeranno,"
        },
        {
          "c": "@vers4",
          "l": "ti |diranno: Che bel |fior!"
        }
      ]
    },
    {
      "label": "Vers 6",
      "lines": [
        {
          "c": "@vers1",
          "l": "È questo il |fiore del |partigiano,"
        },
        {
          "c": "@vers2",
          "l": "O bella, |ciao! Bella, ciao! Bella, |ciao, ciao, ciao!"
        },
        {
          "c": "@vers3",
          "l": "È questo il |fiore del |partigiano,"
        },
        {
          "c": "@vers4",
          "l": "morto |per la |libertà!"
        }
      ]
    }
  ]
}