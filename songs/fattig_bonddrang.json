{
  "title": "Fattig Bonddräng",
  "artist": "Astrid Lindgren / Georg Riedel",
  "key": "G",
  "difficulty": "beginner",
  "sections": [
    {
      "label": "Vers 1",
      "lines": [
        {
          "c": "G             C                  D",
          "l": "Jag är fattig bonddräng, men jag lever ändå."
        },
        {
          "c": "G             C                 D       G",
          "l": "Dagar går och kommer, medan jag knogar på."
        },
        {
          "c": "G              Am7              D          Bm",
          "l": "Harvar, sår och plöjer, mockar, gräver och bär."
        },
        {
          "c": "Em           C            D           G",
          "l": "Går bak mina oxar, hojtar visslar och svär."
        }
      ]
    },
    {
      "label": "Vers 2",
      "lines": [
        {
          "c": "G             C                  D",
          "l": "Jag är fattig bonddräng, och jag tuggar mitt snus."
        },
        {
          "c": "G               C                D          G",
          "l": "Och när lörda'n kommer, vill jag ta mig ett rus."
        },
        {
          "c": "G                  Am7             D         Bm",
          "l": "Sen, när jag blitt livad vill jag tampas och slåss."
        },
        {
          "c": "Em          C               D          G",
          "l": "Vila hos en flicka vill jag också, förstås."
        }
      ]
    },
    {
      "label": "Vers 3",
      "lines": [
        {
          "c": "G              C               D",
          "l": "Sen, då kommer sönda'n, och då vill våran präst,"
        },
        {
          "c": "G             C              D         G",
          "l": "att jag ska i kyrkan, men då sover jag mest."
        },
        {
          "c": "G               Am7       D        Bm",
          "l": "Prästen kan väl sova hela måndagen men,"
        },
        {
          "c": "Em            C                 D        G",
          "l": "för en fattig bonddräng, börjar knoget igen."
        }
      ]
    },
    {
      "label": "Vers 4",
      "lines": [
        {
          "c": "G            C            D",
          "l": "Så går hela veckan, alla dagar och år."
        },
        {
          "c": "G               C            D          G",
          "l": "Jag går med min lie, och jag plöjer och sår."
        },
        {
          "c": "G            Am7          D            Bm",
          "l": "Jag kör mina oxar och jag hässjar mitt hö."
        },
        {
          "c": "Em               C                 D            G",
          "l": "Harvar, gnor och trälar, och till sist ska jag dö."
        }
      ]
    },
    {
      "label": "Vers 5",
      "lines": [
        {
          "c": "G                C               D",
          "l": "Står där, fattig bonddräng invid Himmelens port."
        },
        {
          "c": "G             C              D         G",
          "l": "Lite rädd och ledsen för de synder jag gjort."
        },
        {
          "c": "G            Am7              D           Bm",
          "l": "Man ska inte supa, hålls med flickor och slåss."
        },
        {
          "c": "Em            C              D            G",
          "l": "Herren, Gud i Himlen, är väl missnöjd förstås."
        }
      ]
    },
    {
      "label": "Vers 6",
      "lines": [
        {
          "c": "G             C              D",
          "l": "Men, då säger Herren: Fattig bonddräng, kom hit."
        },
        {
          "c": "G                C                D       G",
          "l": "Jag har sett din strävan och ditt eviga slit."
        },
        {
          "c": "G              Am7              D         Bm",
          "l": "Därför, fattig bonddräng, är Du välkommen här."
        },
        {
          "c": "Em             C                   D        G",
          "l": "Därför, fattig bonddräng, skall Du vara mig när."
        }
      ]
    },
    {
      "label": "Vers 7",
      "lines": [
        {
          "c": "G               C                 D",
          "l": "Åh, jag, fattig bonddräng står så still inför Gud."
        },
        {
          "c": "G                C               D          G",
          "l": "Och sen klär han på mig den mest snövita skrud."
        },
        {
          "c": "G            Am7             D       Bm",
          "l": "Nu Du, säger Herren, är ditt arbete slut."
        },
        {
          "c": "Em            C                 D       G",
          "l": "Nu Du, fattig bonddräng, nu får Du vila ut."
        }
      ]
    }
  ]
}