{
  "title": "Visa Från Utanmyra",
  "artist": "Trad. / Monica Zetterlund",
  "key": "Am",
  "difficulty": "intermediate",
  "sections": [
    {
      "label": "Vers 1",
      "lines": [
        {
          "c": "Am       E7          Am    B7",
          "l": "Endast en gång såg jag den man"
        },
        {
          "c": "Em  E7          Am  E7",
          "l": "mina ögon blev som förvän-da."
        },
        {
          "c": "Am     E7       Am",
          "l": "Såsom vinden gångade han,"
        },
        {
          "c": "      Em    E7         Am  E7",
          "l": "rask och orädd, säker att se-gra."
        },
        {
          "c": "Am      E7         C   C/B",
          "l": "Han såg på mig och han log."
        },
        {
          "c": "C/A     C/F      Bm7b5  E7",
          "l": "Han såg min ros och log,"
        },
        {
          "c": "      Am      E7      Am",
          "l": "sen han gångade mig förbi."
        },
        {
          "c": "      C        Em      Am",
          "l": "Men han gångade mig förbi."
        }
      ]
    },
    {
      "label": "Vers 2",
      "lines": [
        {
          "c": "Am       E7          Am    B7",
          "l": "Endast en gång såg jag den man,"
        },
        {
          "c": "Em  E7          Am  E7",
          "l": "mina ögon blev som förvända."
        },
        {
          "c": "Am     E7+      Am   B7",
          "l": "Såsom solen strålade han,"
        },
        {
          "c": "      Em    E7         Am  E7",
          "l": "all min levnad kom han att än-dra."
        },
        {
          "c": "Am      E7         C   C/B",
          "l": "Han tog på mig och han log."
        },
        {
          "c": "C/A     C/F      Bm7b5  E7",
          "l": "Han tog min ros och log,"
        },
        {
          "c": "      Am      E7      Am",
          "l": "sen han gångade mig förbi."
        },
        {
          "c": "      C        Em      Am",
          "l": "Men han gångade mig förbi"
        }
      ]
    },
    {
      "label": "Vers 3",
      "lines": [
        {
          "c": "Am       E7          Am    B7",
          "l": "Endast en gång såg jag den man,"
        },
        {
          "c": "Em  E7          Am  E7",
          "l": "mina ögon blev som förvända."
        },
        {
          "c": "Am     E7       Am   B7",
          "l": "Sådan man, sån man är han,"
        },
        {
          "c": "      Em    E7         Am  E7",
          "l": "Att hans hand kan livet fullän-dra."
        },
        {
          "c": "Am      E7         C   C/B",
          "l": "Han bröt mitt motstånd, han log."
        },
        {
          "c": "C/A     C/F      Bm7b5  E7",
          "l": "Han bröt min ros och log,"
        },
        {
          "c": "      Am      E7      Am",
          "l": "sen han gångade mig förbi."
        },
        {
          "c": "      C        Em      Am",
          "l": "Men han gångade mig förbi"
        }
      ]
    }
  ]
}